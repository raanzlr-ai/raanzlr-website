{
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "framework": null,
  "env": {
    "DISABLE_ESLINT_PLUGIN": "true",
    "SKIP_PREFLIGHT_CHECK": "true"
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
